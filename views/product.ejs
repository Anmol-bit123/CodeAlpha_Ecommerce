<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> — ShopAlpha</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>
  <nav>
    <a href="/" class="brand">🛍 ShopAlpha</a>
    <div class="nav-links">
      <% if (currentUser) { %>
        <a href="/cart">🛒 Cart</a>
        <a href="/orders">My Orders</a>
        <form method="POST" action="/logout" style="display:inline;">
          <button class="btn btn-outline btn-sm">Logout</button>
        </form>
      <% } else { %>
        <a href="/login">Log in</a>
        <a href="/register" class="btn btn-primary btn-sm">Register</a>
      <% } %>
    </div>
  </nav>

  <div class="container">
    <% if (success.length) { %><div class="flash flash-success"><%= success %></div><% } %>
    <% if (error.length) { %><div class="flash flash-error"><%= error %></div><% } %>

    <div class="product-detail">
      <img src="<%= product.image_url %>" alt="<%= product.name %>"/>
      <div class="product-detail-info">
        <h1><%= product.name %></h1>
        <div class="price">₹<%= product.price.toLocaleString('en-IN') %></div>
        <span class="stock-badge">✓ <%= product.stock %> in stock</span>
        <p><%= product.description %></p>

        <% if (currentUser) { %>
          <form method="POST" action="/cart/add">
            <input type="hidden" name="product_id" value="<%= product.id %>"/>
            <input type="hidden" name="name" value="<%= product.name %>"/>
            <input type="hidden" name="price" value="<%= product.price %>"/>
            <div class="qty-row">
              <label for="quantity">Quantity</label>
              <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock %>"/>
            </div>
            <button type="submit" class="btn btn-primary">Add to Cart</button>
          </form>
        <% } else { %>
          <a href="/login" class="btn btn-primary">Log in to Purchase</a>
        <% } %>

        <div style="margin-top:16px;">
          <a href="/" class="btn btn-outline">← Back to Products</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
