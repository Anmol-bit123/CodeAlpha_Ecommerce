<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ShopAlpha - Home</title>
  <link rel="stylesheet" href="/style.css"/>
</head>
<body>
  <nav>
    <a href="/" class="brand">ShopAlpha</a>
    <div class="nav-links">
      <% if (currentUser) { %>
        <a href="/cart">Cart</a>
        <a href="/orders">My Orders</a>
        <span class="nav-user">Hi, <%= currentUser.username %></span>
        <form method="POST" action="/logout" style="display:inline;">
          <button class="btn btn-ghost btn-sm">Logout</button>
        </form>
      <% } else { %>
        <a href="/login">Login</a>
        <a href="/register" class="btn btn-primary btn-sm">Register</a>
      <% } %>
    </div>
  </nav>

  <div class="container">
    <% if (error && error.length) { %><div class="flash flash-error"><%= error %></div><% } %>
    <% if (success && success.length) { %><div class="flash flash-success"><%= success %></div><% } %>

    <div class="page-header">
      <h1>All Products</h1>
      <p>Browse our collection of products</p>
    </div>

    <div class="product-grid">
      <% for (let product of products) { %>
        <div class="product-card">
          <img src="<%= product.image_url %>" alt="<%= product.name %>"/>
          <div class="product-card-body">
            <h3><%= product.name %></h3>
            <p><%= product.description.substring(0, 65) %>...</p>
            <div class="product-price">Rs. <%= Number(product.price).toLocaleString('en-IN') %></div>
            <div class="product-actions">
              <a href="/products/<%= product.id %>" class="btn btn-outline btn-sm">Details</a>
              <% if (currentUser) { %>
                <form method="POST" action="/cart/add">
                  <input type="hidden" name="product_id" value="<%= product.id %>"/>
                  <input type="hidden" name="name" value="<%= product.name %>"/>
                  <input type="hidden" name="price" value="<%= product.price %>"/>
                  <input type="hidden" name="quantity" value="1"/>
                  <button class="btn btn-primary btn-sm">Add to Cart</button>
                </form>
              <% } else { %>
                <a href="/login" class="btn btn-primary btn-sm">Add to Cart</a>
              <% } %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
